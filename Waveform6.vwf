<tnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=off --flatten_buses=off --timescale=1ps --tool=modelsim_oem --format=verilog --output_directory="C:/Users/PC/Desktop/EE Years/Second Term (1447)/EE360-Digital 1/Project Folder/simulation/qsim/" full_adder -c full_adder</tnetlist_cmd>
