module sign_control_xor(
    input [11:0] aX2_magnitude,
    input [7:0] bX_magnitude,
    input [3:0] c_magnitude,
    input Sa, Sb, Sc,
    output [11:0] signed_aX2, signed_bX, signed_c
);

    wire [11:0] bX_extended = {4'b0, bX_magnitude};
    wire [11:0] c_extended = {8'b0, c_magnitude};

    // XOR-based 2's complement in one step
    // When sign=1: number ^ 111...1 + 1 = ~number + 1 = -number
    // When sign=0: number ^ 000...0 + 0 = number
    assign signed_aX2 = (aX2_magnitude ^ {12{Sa}}) + Sa;
    assign signed_bX = (bX_extended ^ {12{Sb}}) + Sb;
    assign signed_c = (c_extended ^ {12{Sc}}) + Sc;

endmodule